TF_VAR_do_token=""
TF_VAR_db_password=""
TF_VAR_ssh_key_fingerprint="..."
TF_VAR_git_repo_url="git@github.com:mardo/tradan.git"
TF_VAR_ssh_key_name="mardo"

# Symbols to ingest (Terraform map as JSON). Add more symbols as needed.
# TF_VAR_symbols='{"BTCUSDT":{"start":"2020-01","end":"2026-04"},"ETHUSDT":{"start":"2021-06","end":"2026-04"}}'

# Set to true to enable fill-gaps/retry loop after initial ingest run (default: false)
# TF_VAR_ingest_retry_enabled=true

# DB firewall: CIDRs outside the VPC allowed to reach Postgres. Inner strings MUST be quoted (HCL list of strings).
# TF_VAR_db_worker_ips='["203.0.113.1/32","198.51.100.2/32"]'
