# =============================================================
# Tradan — Drift + Ranger Strategy Bot
# Copy to .env and fill in your values
# =============================================================

# Solana RPC endpoint (use a paid provider like Helius in production)
RPC_URL=https://api.devnet.solana.com

# Bot wallet private key as a JSON array of numbers
# Generate with: solana-keygen new --outfile bot-wallet.json
# Get array with: cat bot-wallet.json
BOT_PRIVATE_KEY=[]

# Drift environment: "devnet" | "mainnet-beta"
DRIFT_ENV=devnet

# Ranger vault public key (set after creating vault on https://vaults.ranger.finance/create)
RANGER_VAULT_ADDRESS=

# Drift sub-account ID to use (default: 0)
DRIFT_SUBACCOUNT_ID=0

# Trading config
MARKET_INDEX=0          # 0 = SOL-PERP on Drift
BASE_ASSET_AMOUNT=1     # Size of each trade in base asset units (e.g. 1 SOL)
MAX_LEVERAGE=3          # Maximum allowed leverage (e.g. 3x)
STOP_LOSS_PCT=0.03      # Stop loss as a fraction (e.g. 0.03 = 3%)
LOOP_INTERVAL_MS=15000  # How often the bot loop runs (milliseconds)

# Kill switch — set to "true" to immediately stop all trading
KILL_SWITCH=false
