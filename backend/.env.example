# Standard Postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/tradan

# Neon (append ?sslmode=require for the direct connection,
# or use the -pooler hostname for the pooled endpoint)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://user:pass@localhost:5432/tradan

# Optional: DEBUG logs every Binance URL, batches, and full tracebacks on stderr
# INGEST_LOG_LEVEL=DEBUG
MODELS_RSYNC_TARGET=root@BASE_PUBLIC_IP:/mnt/models
MODELS_SSH_KEY=~/.ssh/id_ed25519
